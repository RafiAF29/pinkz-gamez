# ════════════════════════════════════════
# Bytes & Bites PS Rental — Environment
# Salin file ini menjadi .env dan isi nilainya
# ════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# Secret untuk JWT/session token (ganti dengan string random panjang)
SESSION_SECRET=ganti_dengan_random_string_minimal_32_karakter

# Pending booking TTL (dalam menit)
PENDING_TTL_MINUTES=15

# Session TTL (dalam jam)
SESSION_TTL_HOURS=8

# ── DATABASE MySQL (XAMPP) ──
# Uncomment dan isi untuk aktifkan MySQL mode
# STORAGE_MODE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=bytes_bites_rental
# DB_USER=root
# DB_PASS=          ← XAMPP default: kosong
# DB_POOL_MIN=2
# DB_POOL_MAX=10
#
# LANGKAH AKTIVASI MYSQL:
# 1. Start XAMPP → Start Apache & MySQL
# 2. Buka phpMyAdmin → http://localhost/phpmyadmin
# 3. Import schema: backend/schema/mysql.sql
# 4. Jalankan migrasi data: node backend/schema/migrate_json_to_mysql.js
# 5. Uncomment STORAGE_MODE=mysql dan DB_* di atas
# 6. npm install mysql2
# 7. Restart: node server.js

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_LOGIN_MAX=10

# ── CORS (pisahkan dengan koma jika lebih dari 1) ──
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── WhatsApp Admin ──
WA_ADMIN_NUMBER=6281234567890

# ── Mode storage: json | mysql ──
STORAGE_MODE=json
